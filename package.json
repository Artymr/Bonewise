{
  "name": "bonewise",
  "version": "0.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "node ./bin/www",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "ejs": "~2.6.1",
    "electron-updater": "^6.8.3",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "mongoose": "^9.1.5",
    "morgan": "~1.9.1"
  },
  "build": {
    "appId": "com.bonewise.app",
    "productName": "BoneWise",
    "artifactName": "BoneWise.exe",
    "win": {
      "target": "nsis",
      "icon": "build/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish":{
      "provider": "github",
      "owner": "Artym",
      "repo": "BoneWise"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!*.vbs",
      "!*.cmd"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
